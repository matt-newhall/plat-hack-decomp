  "messages": [
    {
      "id": "Route229_Text_MakeItUpWithThis",
      "en_US": [
        "Were you looking for me?\n",
        "Did you miss me?\r",
        "I wish I had a new nugget of wisdom\n",
        "to share with you, but alas, I don’t!\r",
        "So, I’ll have to make it up to you\n",
        "with this!\r"
      ]
    },
    {
      "id": "Route229_Text_TakeAnother",
      "en_US": [
        "Oh, why not? Take another!\n",
        "It makes up for the wisdom I lack!\r"
      ]
    },
    {
      "id": "Route229_Text_ThoseAreMyNuggets",
      "en_US": [
        "Those are my Nuggets!\n",
        "Try to spend them wisely!\r",
        "Nuggets of gold have to be worth\n",
        "more than nuggets of my wisdom!"
      ]
    },
    {
      "id": "Route229_Text_SignRt229ResortArea",
      "en_US": [
        "Rt. 229\n",
        "Resort Area"
      ]
    },
    {
      "id": "Route229_Text_BlockDesertPersonSpeak",
      "en_US": [
        "Hey pal, the desert’s blocked\n",
        "currently, huge dust clouds.\r",
        "If you want to head over to the\n",
        "Fight Area, I’d recommend going\f",
        "south and then west through\f",
        "Route 230.\r",
        "Oh, thought you could skip it?\r",
        "Nice try, lol."
      ]
    }
  ]
}
