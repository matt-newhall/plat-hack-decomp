    {
      "id": "Route203_Text_TrainerTipsIfAPokemonIsAboutToEvolveItCanBeInstantlyStopped",
      "en_US": [
        "Trainer Tips!\r",
        "If a Pokémon is about to evolve,\n",
        "it can be instantly stopped.\r",
        "Press the B Button during evolution\n",
        "to startle the Pokémon into stopping.\r",
        "That is how evolution can be\n",
        "canceled."
      ]
    },
    {
      "id": "Route203_Text_TrainerTipsPokemonMovesUseEnergyCalledPowerPoints",
      "en_US": [
        "Trainer Tips!\r",
        "Pokémon moves use energy called\n",
        "Power Points, or PP for short.\r",
        "If the PP of moves runs low, head for\n",
        "any Pokémon Center."
      ]
    }
  ]
}
